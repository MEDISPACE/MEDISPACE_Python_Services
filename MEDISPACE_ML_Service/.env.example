# ML Service Environment Variables
# Copy file này thành .env và điền giá trị thực

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=medispace

# Service config
PORT=8002
ML_RETRAIN_INTERVAL_HOURS=6

# Thresholds
SVD_MIN_USERS=10
FPGROWTH_MIN_TRANSACTIONS=50
FPGROWTH_MIN_SUPPORT=0.01
FPGROWTH_MIN_CONFIDENCE=0.3
