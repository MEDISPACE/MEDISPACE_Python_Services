# Gemma LLM API
CUSTOM_LLM_BASE_URL=https://llm.datateam.space
CUSTOM_LLM_MODEL=gemma-4-e4b-it.gguf
CUSTOM_LLM_MAX_TOKENS=2048
CUSTOM_LLM_IMAGE_MAX_TOKENS=6144
CUSTOM_LLM_TIMEOUT_SECONDS=150
