# MongoDB (same as BE)
MONGO_URI=mongodb://localhost:27017
DB_NAME=medispace
DB_PATIENT_MEDICAL_COLLECTION=patient_medical_infos

# Typesense (for RAG - Phase 2)
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=your_typesense_api_key
